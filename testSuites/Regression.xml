<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite" parallel="tests" thread-count="2">
 <groups>
	<run>
		<include name="Regression"/>	
	</run>
</groups>
<listeners>
	<listener class-name="utils.listeners.Listeners"/>
	<listener class-name="triage.history.TestRunHistoryListener"/>
</listeners>
<test thread-count="5" name="LogIn">
    <classes>
      <class name="testCases.LogIn"/>
    </classes>
  </test>
  <test thread-count="5" name="SignUp">
    <classes>
      <class name="testCases.SignUp"/>
    </classes>
  </test>
  <test thread-count="5" name="Cart">
    <classes>
      <class name="testCases.Cart"/>
    </classes>
  </test>
  <test thread-count="5" name="CheckOut">
    <classes>
      <class name="testCases.CheckOut"/>
    </classes>
  </test>
</suite>